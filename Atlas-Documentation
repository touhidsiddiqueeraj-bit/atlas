<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Atlas — Developer Documentation</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Mono:ital,wght@0,400;0,500;1,400&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg:    #0d0d14;
    --bg2:   #13131f;
    --surf:  #1a1a2a;
    --elev:  #202033;
    --bdr:   rgba(255,255,255,.08);
    --acc:   #7c6aff;
    --acc2:  #9d8fff;
    --grn:   #2dd4a0;
    --amb:   #f5a623;
    --red:   #ff5f6d;
    --tx1:   #e8e8f5;
    --tx2:   #a0a0bc;
    --tx3:   #5a5a72;
    --mono:  'DM Mono', monospace;
    --sans:  'DM Sans', sans-serif;
    --disp:  'Syne', sans-serif;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--tx1);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.7;
    min-height: 100vh;
  }

  /* ── Layout ── */
  .layout { display: flex; min-height: 100vh; }

  /* ── Sidebar nav ── */
  .doc-nav {
    width: 240px;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    background: var(--bg2);
    border-right: 1px solid var(--bdr);
    padding: 28px 0 40px;
    scrollbar-width: thin;
    scrollbar-color: var(--bdr) transparent;
  }
  .doc-nav::-webkit-scrollbar { width: 4px; }
  .doc-nav::-webkit-scrollbar-thumb { background: var(--bdr); border-radius: 2px; }

  .nav-logo {
    font-family: var(--disp);
    font-size: 20px;
    font-weight: 800;
    color: var(--acc2);
    padding: 0 20px 24px;
    letter-spacing: -0.5px;
  }
  .nav-logo span { color: var(--tx3); font-weight: 700; font-size: 11px; display: block; margin-top: 2px; letter-spacing: 1.5px; text-transform: uppercase; font-family: var(--sans); }

  .nav-group { margin-bottom: 6px; }
  .nav-group-label {
    font-size: 10px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.4px;
    color: var(--tx3);
    padding: 8px 20px 4px;
  }
  .nav-link {
    display: block;
    padding: 6px 20px;
    font-size: 13px;
    color: var(--tx2);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: all .15s;
    line-height: 1.4;
  }
  .nav-link:hover  { color: var(--tx1); background: rgba(124,106,255,.06); border-left-color: var(--bdr); }
  .nav-link.active { color: var(--acc2); border-left-color: var(--acc); background: rgba(124,106,255,.08); }
  .nav-link.sub    { padding-left: 32px; font-size: 12px; }

  /* ── Main content ── */
  .doc-content {
    flex: 1;
    min-width: 0;
    padding: 48px 64px 120px;
    max-width: 900px;
  }

  /* ── Typography ── */
  h1 {
    font-family: var(--disp);
    font-size: 40px;
    font-weight: 800;
    color: var(--tx1);
    letter-spacing: -1.5px;
    line-height: 1.1;
    margin-bottom: 12px;
  }
  h1 .accent { color: var(--acc2); }

  h2 {
    font-family: var(--disp);
    font-size: 26px;
    font-weight: 700;
    color: var(--tx1);
    letter-spacing: -0.5px;
    margin: 56px 0 16px;
    padding-top: 56px;
    border-top: 1px solid var(--bdr);
    scroll-margin-top: 24px;
  }
  h2:first-of-type { border-top: none; margin-top: 0; padding-top: 0; }

  h3 {
    font-size: 16px;
    font-weight: 500;
    color: var(--acc2);
    margin: 28px 0 10px;
    scroll-margin-top: 24px;
  }

  h4 {
    font-size: 13px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--tx3);
    margin: 20px 0 8px;
  }

  p { margin-bottom: 14px; color: var(--tx2); }
  p strong { color: var(--tx1); font-weight: 500; }
  p a, li a { color: var(--acc2); text-decoration: none; }
  p a:hover, li a:hover { text-decoration: underline; }

  ul, ol { padding-left: 20px; margin-bottom: 14px; color: var(--tx2); }
  li { margin-bottom: 5px; }
  li strong { color: var(--tx1); }
  li code { font-family: var(--mono); font-size: 12px; background: var(--elev); padding: 1px 5px; border-radius: 3px; color: var(--acc2); }

  /* ── Hero ── */
  .hero {
    margin-bottom: 48px;
    padding-bottom: 36px;
    border-bottom: 1px solid var(--bdr);
  }
  .hero-sub {
    font-size: 16px;
    color: var(--tx3);
    margin-top: 10px;
    line-height: 1.5;
  }
  .badge-row { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 18px; }
  .badge {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px;
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 20px;
    font-size: 11px;
    color: var(--tx2);
  }
  .badge .dot { width: 6px; height: 6px; border-radius: 50%; background: var(--grn); }
  .badge.warn .dot { background: var(--amb); }
  .badge.info .dot { background: var(--acc); }

  /* ── Code blocks ── */
  pre {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 8px;
    padding: 16px 18px;
    overflow-x: auto;
    margin: 12px 0 18px;
    font-family: var(--mono);
    font-size: 12.5px;
    line-height: 1.6;
    color: var(--tx1);
    position: relative;
  }
  pre .com  { color: var(--tx3); }
  pre .kw   { color: var(--acc2); }
  pre .str  { color: var(--grn); }
  pre .fn   { color: #f5a623; }
  pre .num  { color: #ff8b8b; }

  code {
    font-family: var(--mono);
    font-size: 12px;
    background: var(--elev);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--acc2);
  }
  pre code { background: none; padding: 0; font-size: inherit; color: inherit; }

  /* ── Tables ── */
  .table-wrap { overflow-x: auto; margin: 12px 0 20px; }
  table { width: 100%; border-collapse: collapse; font-size: 13px; }
  th {
    text-align: left;
    padding: 8px 14px;
    background: var(--surf);
    color: var(--tx3);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 500;
    border-bottom: 1px solid var(--bdr);
  }
  td {
    padding: 9px 14px;
    color: var(--tx2);
    border-bottom: 1px solid rgba(255,255,255,.04);
    vertical-align: top;
  }
  td code { font-size: 11px; }
  tr:last-child td { border-bottom: none; }
  tr:hover td { background: rgba(255,255,255,.02); }

  /* ── Callouts ── */
  .callout {
    display: flex;
    gap: 12px;
    padding: 14px 16px;
    border-radius: 8px;
    margin: 16px 0;
    font-size: 13.5px;
    line-height: 1.6;
  }
  .callout-icon { flex-shrink: 0; font-size: 16px; margin-top: 1px; }
  .callout-body { color: var(--tx2); }
  .callout-body strong { color: var(--tx1); }
  .callout.note  { background: rgba(124,106,255,.08); border: 1px solid rgba(124,106,255,.2); }
  .callout.warn  { background: rgba(245,166,35,.07);  border: 1px solid rgba(245,166,35,.2); }
  .callout.tip   { background: rgba(45,212,160,.07);  border: 1px solid rgba(45,212,160,.2); }
  .callout.danger { background: rgba(255,95,109,.07); border: 1px solid rgba(255,95,109,.2); }

  /* ── Section cards ── */
  .card-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; margin: 16px 0 24px; }
  .card {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 8px;
    padding: 14px 16px;
    transition: border-color .15s;
  }
  .card:hover { border-color: rgba(124,106,255,.3); }
  .card-title { font-size: 13px; font-weight: 500; color: var(--tx1); margin-bottom: 4px; }
  .card-desc  { font-size: 12px; color: var(--tx3); line-height: 1.5; }
  .card-icon  { font-size: 18px; margin-bottom: 6px; }

  /* ── Flow diagram ── */
  .flow {
    background: var(--surf);
    border: 1px solid var(--bdr);
    border-radius: 8px;
    padding: 20px;
    margin: 16px 0;
    font-family: var(--mono);
    font-size: 12px;
    color: var(--tx2);
    line-height: 2;
  }
  .flow .node  { color: var(--tx1); }
  .flow .arrow { color: var(--tx3); }
  .flow .yes   { color: var(--grn); }
  .flow .no    { color: var(--red); }
  .flow .end   { color: var(--acc2); }

  /* ── Divider ── */
  .divider { border: none; border-top: 1px solid var(--bdr); margin: 32px 0; }

  /* ── Key-value pairs ── */
  .kv { display: grid; grid-template-columns: 180px 1fr; gap: 6px 16px; margin: 10px 0 18px; font-size: 13px; }
  .kv-key   { color: var(--tx3); font-family: var(--mono); font-size: 12px; padding-top: 2px; }
  .kv-val   { color: var(--tx2); }

  /* ── State tree ── */
  .state-block { background: var(--surf); border: 1px solid var(--bdr); border-radius: 8px; padding: 16px 18px; margin: 12px 0; font-family: var(--mono); font-size: 12px; line-height: 1.8; }
  .state-block .s-key   { color: var(--acc2); }
  .state-block .s-type  { color: var(--tx3); }
  .state-block .s-desc  { color: var(--tx2); margin-left: 8px; }
  .state-block .s-head  { color: var(--amb); }

  /* ── Storage diagram ── */
  .storage-row { display: flex; align-items: flex-start; gap: 12px; padding: 10px 14px; background: var(--surf); border: 1px solid var(--bdr); border-radius: 6px; margin-bottom: 8px; }
  .storage-row .sr-icon { font-size: 18px; flex-shrink: 0; margin-top: 2px; }
  .storage-row .sr-name { font-size: 13px; color: var(--tx1); font-weight: 500; }
  .storage-row .sr-desc { font-size: 12px; color: var(--tx3); margin-top: 2px; }
  .storage-row .sr-badge { font-size: 10px; font-family: var(--mono); padding: 2px 6px; background: var(--elev); border-radius: 3px; color: var(--acc2); margin-left: 8px; }

  /* ── Top anchor helper ── */
  .section-anchor { display: block; height: 0; }

  /* ── Responsive ── */
  @media (max-width: 900px) {
    .doc-nav { display: none; }
    .doc-content { padding: 32px 24px 80px; }
    h1 { font-size: 30px; }
    .card-grid { grid-template-columns: 1fr; }
  }
</style>
</head>
